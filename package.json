{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,vite -c blue,green \"npm run dev:api\" \"wait-on -t 120000 http-get://127.0.0.1:8000/health && vite\"",
    "dev:client": "vite",
    "dev:api": "cd ../backend && venv\\Scripts\\python.exe -m uvicorn app.main:app --reload --reload-dir ./app --host 127.0.0.1 --port 8000",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
