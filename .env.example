# Vite dev server reads VITE_* only. Restart after changes.
#
# From frontend/: npm run dev — starts FastAPI on :8000 and Vite (proxy /api → 8000).
# If the API is already running: npm run dev:client

# Same values as backend SUPABASE_URL; anon key from Supabase → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase → Authentication → URL configuration:
#   Site URL: http://localhost:5173 (or your deployed origin)
#   Redirect URLs (allow list), add each origin you use:
#     http://localhost:5173/**
#     http://localhost:5173/auth/confirm
#     http://localhost:5173/reset-password
#   Enable email confirmations if you want verify-before-login signup.

# Optional: call backend on another origin (default: empty = same-origin + Vite proxy)
# VITE_BACKEND_ORIGIN=http://127.0.0.1:8000
