# Vite dev server reads VITE_* only. Restart after changes.
#
# From frontend/: npm run dev — starts FastAPI on :8000 and Vite (proxy /api → 8000).
# If the API is already running: npm run dev:client

# Razorpay Standard Checkout (publishable key id only — must match backend RAZORPAY_KEY_ID)
# VITE_RAZORPAY_KEY_ID=rzp_test_...

# Same values as backend SUPABASE_URL; anon key from Supabase → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: canonical site for SEO / OG (no trailing slash). If unset: dev uses http://localhost:5173, prod build uses https://www.porpin.com.
# VITE_SITE_ORIGIN=https://www.porpin.com

# Supabase → Authentication → URL configuration:
#   Site URL: https://www.porpin.com (production) or http://localhost:5173 (dev)
#   Redirect URLs (allow list), add each origin you use, e.g.:
#     https://www.porpin.com/**
#     https://www.porpin.com/auth/confirm
#     https://www.porpin.com/reset-password
#     http://localhost:5173/**  (for local dev)
#   Enable email confirmations if you want verify-before-login signup.

# If the API is on another host (not same-origin as the static site), set full backend origin
# (host only, no /api path — the app appends /api/...):
# VITE_BACKEND_ORIGIN=https://api.porpin.com
#
# Local dev: usually leave this unset. The Vite dev server proxies /api → http://127.0.0.1:8000.
# Setting VITE_BACKEND_ORIGIN=http://127.0.0.1:8000 can cause confusing 404s if a different
# process is listening on :8000 than the one `npm run dev` expects.
